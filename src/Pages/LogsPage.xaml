<Page x:Class="HotspotShare.Pages.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24"
              MaxWidth="1280">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="执行日志" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodySecondaryTextBlockStyle}"
                               Text="最近执行记录会按级别、分类和时间结构化展示，方便快速定位异常和回看操作轨迹。" />
                </StackPanel>

                <ui:Button Grid.Column="1"
                           Padding="14,8"
                           VerticalAlignment="Top"
                           Appearance="Secondary"
                           Content="清空日志"
                           Icon="{ui:SymbolIcon Delete20}"
                           Command="{Binding ClearLogCommand}" />
            </Grid>

            <WrapPanel Grid.Row="1"
                       Margin="0,20,0,0">
                <Border Style="{StaticResource LogMetricBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="最近日志" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                   Text="{Binding LogCountValue}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource LogMetricBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="错误" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                   Text="{Binding ErrorLogCountValue}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource LogMetricBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="警告" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                   Text="{Binding WarningLogCountValue}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource LogMetricBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="最近时间" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                   Text="{Binding LatestLogTimeValue}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Grid Grid.Row="2"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.9*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelCardBorderStyle}"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="20,18,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Text="日志流" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="按时间倒序浏览最近日志，选中后可在右侧查看完整细节。" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Style="{StaticResource LogTagBorderStyle}"
                                    Padding="10,5"
                                    VerticalAlignment="Top">
                                <TextBlock Style="{StaticResource LogMetaTextBlockStyle}"
                                           Text="{Binding LogCountValue, StringFormat=共 {0} 条}" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="16,18,16,16">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="当前还没有日志记录。&#x0a;执行热点操作、刷新状态或出现异常后，这里会自动更新。">
                                <TextBlock.Style>
                                    <Style BasedOn="{StaticResource BodySecondaryTextBlockStyle}"
                                           TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=RecentLogsList, Path=HasItems}"
                                                         Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ListBox x:Name="RecentLogsList"
                                     ItemsSource="{Binding RecentLogs}"
                                     SelectedItem="{Binding SelectedLogEntry, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Visibility="{Binding ElementName=RecentLogsList, Path=HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,10" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder"
                                                            Padding="14,12"
                                                            CornerRadius="10"
                                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                            BorderThickness="1">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder"
                                                                    Property="Background"
                                                                    Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder"
                                                                    Property="Background"
                                                                    Value="{DynamicResource LayerOnMicaBaseAltFillColorSecondaryBrush}" />
                                                            <Setter TargetName="ItemBorder"
                                                                    Property="BorderBrush"
                                                                    Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                                    <Border Width="4"
                                                            Margin="0,4,12,4"
                                                            CornerRadius="999">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Information">
                                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Style="{StaticResource LogTagBorderStyle}"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Style="{StaticResource LogTagTextBlockStyle}"
                                                                   Text="{Binding Level}" />
                                                    </Border>

                                                    <Border Grid.Column="1"
                                                            Style="{StaticResource LogTagBorderStyle}"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Style="{StaticResource LogTagTextBlockStyle}"
                                                                   Text="{Binding Category}" />
                                                    </Border>

                                                    <Border Grid.Column="2"
                                                            Style="{StaticResource LogTagBorderStyle}"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Style="{StaticResource LogTagTextBlockStyle}"
                                                                   Text="{Binding EventIdDisplay, StringFormat=事件 {0}}" />
                                                    </Border>

                                                    <TextBlock Grid.Column="3"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource LogMetaTextBlockStyle}"
                                                               Text="{Binding TimestampDisplay}" />
                                                </Grid>

                                                <TextBlock Margin="0,6,0,0"
                                                            Style="{StaticResource LogPrimaryTextBlockStyle}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Message}"
                                                            TextTrimming="CharacterEllipsis"
                                                            TextWrapping="NoWrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Margin="12,0,0,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top">
                                                <Border Style="{StaticResource LogTagBorderStyle}">
                                                    <TextBlock Style="{StaticResource LogTagTextBlockStyle}"
                                                               Text="{Binding SourceDisplay}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        Padding="18"
                        Style="{StaticResource PanelCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="日志详情" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="{Binding SelectedLogEntry.Message, TargetNullValue=选择左侧日志查看完整详情}" />
                        </StackPanel>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,18,0,0">
                            <Border Style="{StaticResource StatusChipBorderStyle}"
                                    Padding="12,10"
                                    Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="时间" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedLogEntry.TimestampDisplay, TargetNullValue=-}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatusChipBorderStyle}"
                                    Padding="12,10"
                                    Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="级别" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedLogEntry.Level, TargetNullValue=-}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatusChipBorderStyle}"
                                    Padding="12,10"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}" Text="分类" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedLogEntry.Category, TargetNullValue=-}" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Grid Grid.Row="2"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="12"
                                    Style="{StaticResource PanelCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DetailLabelTextBlockStyle}" Text="事件 ID" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource LogPrimaryTextBlockStyle}"
                                               Text="{Binding SelectedLogEntry.EventIdDisplay}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="12"
                                    Style="{StaticResource PanelCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DetailLabelTextBlockStyle}" Text="来源" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource LogPrimaryTextBlockStyle}"
                                               Text="{Binding SelectedLogEntry.SourceDisplay}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="3"
                                    Margin="0,16,0,0">
                            <Border Padding="14"
                                    Style="{StaticResource PanelCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DetailLabelTextBlockStyle}" Text="详情" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="108"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             CaretBrush="{DynamicResource TextFillColorPrimaryBrush}"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding SelectedLogEntry.DetailsDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Padding="14"
                                    Style="{StaticResource PanelCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DetailLabelTextBlockStyle}" Text="异常" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="180"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             CaretBrush="{DynamicResource TextFillColorPrimaryBrush}"
                                             FontFamily="Consolas"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding SelectedLogEntry.ExceptionDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
