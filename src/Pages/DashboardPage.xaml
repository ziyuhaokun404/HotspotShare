<Page x:Class="HotspotShare.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:HotspotShare.ViewModels"
      mc:Ignorable="d"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24"
                    MaxWidth="1280">
            <ui:Card Margin="0,0,0,16"
                     Padding="28"
                     Background="{DynamicResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                     BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                     BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="70"
                                    Height="70"
                                    CornerRadius="22"
                                    Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
                                <ui:SymbolIcon Symbol="Wifi324"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="18,0,0,0">
                                <TextBlock FontSize="32"
                                           FontWeight="SemiBold"
                                           Text="Windows 移动热点共享" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="选择网络连接，一键创建 Wi-Fi 热点并共享给其他设备。" />
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Margin="0,24,0,0">
                            <Border Style="{StaticResource StatusChipBorderStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="GlobeDesktop24"
                                                       FontSize="14" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Style="{StaticResource MetricLabelTextBlockStyle}"
                                                   Text="共享连接" />
                                    </StackPanel>
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource MetricValueTextBlockStyle}"
                                               Text="{Binding HeroProfileValue}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatusChipBorderStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Wifi324"
                                                       FontSize="14" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Style="{StaticResource MetricLabelTextBlockStyle}"
                                                   Text="热点状态" />
                                    </StackPanel>
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource MetricValueTextBlockStyle}"
                                               Text="{Binding HeroStateValue}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatusChipBorderStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="People24"
                                                       FontSize="14" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Style="{StaticResource MetricLabelTextBlockStyle}"
                                                   Text="连接设备数" />
                                    </StackPanel>
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource MetricValueTextBlockStyle}"
                                               Text="{Binding HeroClientCount}" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <ui:Card Grid.Column="1"
                            Margin="24,0,0,0"
                            Padding="22">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="使用前检查" />
                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="1. 确保无线网卡支持 Windows 移动热点。" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="2. 以管理员身份运行可以避免共享配置失败。" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="3. 热点密码长度必须在 8 到 63 位之间。" />
                        </StackPanel>
                    </ui:Card>
                </Grid>
            </ui:Card>

            <ui:InfoBar Margin="0,0,0,16"
                        IsOpen="True"
                        IsClosable="False"
                        Severity="{Binding AdminSeverity}"
                        Title="{Binding AdminTitle}"
                        Message="{Binding AdminMessage}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.18*" />
                    <ColumnDefinition Width="0.92*" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0"
                         Margin="0,0,16,0"
                         Padding="24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                   Text="共享设置" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource BodySecondaryTextBlockStyle}"
                                   Text="选择来源连接并设置热点名称与密码。" />

                        <Border Margin="0,20,0,20"
                                Height="1"
                                Background="{DynamicResource ControlStrokeColorSecondaryBrush}" />

                        <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="要共享的连接" />
                        <ComboBox Margin="0,8,0,0"
                                  MinHeight="42"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource BodySecondaryTextBlockStyle}"
                                   Text="{Binding ProfileHint}" />

                        <TextBlock Margin="0,22,0,0"
                                   Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="热点名称（SSID）" />
                        <ui:TextBox Margin="0,8,0,0"
                                    MinHeight="42"
                                    MaxLength="32"
                                    ClearButtonEnabled="True"
                                    PlaceholderText="例如 MyHotspot"
                                    Icon="{ui:SymbolIcon Wifi324}"
                                    Text="{Binding Ssid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

                        <TextBlock Margin="0,22,0,0"
                                   Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="Wi-Fi 频段" />
                        <ComboBox Margin="0,8,0,0"
                                  MinHeight="42"
                                  ItemsSource="{x:Static vm:MainWindowViewModel.BandOptions}"
                                  SelectedIndex="{Binding SelectedBandIndex, Mode=TwoWay}"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

                        <TextBlock Margin="0,22,0,0"
                                   Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="热点密码" />
                        <ui:PasswordBox Margin="0,8,0,0"
                                        MinHeight="42"
                                        MaxLength="63"
                                        RevealButtonEnabled="True"
                                        PlaceholderText="至少 8 位"
                                        Icon="{ui:SymbolIcon Password24}"
                                        Password="{Binding Passphrase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource BodySecondaryTextBlockStyle}"
                                   Text="建议使用字母和数字组合，避免特殊字符导致某些终端连接失败。" />

                        <WrapPanel Margin="0,24,0,0">
                            <ui:Button Margin="0,0,12,0"
                                       Padding="16,10"
                                       Content="刷新连接"
                                       Appearance="Secondary"
                                       Icon="{ui:SymbolIcon ArrowClockwise20}"
                                       Command="{Binding RefreshProfilesCommand}"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            <ui:Button Margin="0,0,12,0"
                                       Padding="16,10"
                                       Content="生成密码"
                                       Appearance="Secondary"
                                       Icon="{ui:SymbolIcon Key20}"
                                       Command="{Binding GeneratePasswordCommand}"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            <CheckBox Margin="4,0,0,0"
                                      Content="自动刷新"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsAutoRefreshEnabled, Mode=TwoWay}" />
                        </WrapPanel>

                        <WrapPanel Margin="0,16,0,0">
                            <ui:Button Margin="0,0,12,0"
                                       Padding="16,10"
                                       Content="启动热点并共享"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon Play20}"
                                       Command="{Binding StartSharingCommand}"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            <ui:Button Margin="0,0,12,0"
                                       Padding="16,10"
                                       Content="停止热点"
                                       Appearance="Danger"
                                       Icon="{ui:SymbolIcon Stop20}"
                                       Command="{Binding StopSharingCommand}"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        </WrapPanel>

                        <ui:Card Margin="0,24,0,0"
                                Padding="16">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="操作建议" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="先确认来源连接已联网，再启动热点。移动热点启动后，状态区会显示当前 SSID、连接设备数和最近一次操作结果。" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="1"
                         Padding="24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                   Text="当前状态" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource BodySecondaryTextBlockStyle}"
                                   Text="实时展示当前热点共享状态。" />

                        <ui:InfoBar Margin="0,18,0,0"
                                    IsOpen="True"
                                    IsClosable="False"
                                    Severity="{Binding ResultSeverity}"
                                    Title="{Binding ResultTitle}"
                                    Message="{Binding ResultMessage}" />

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}"
                                       Text="共享连接" />
                            <TextBlock Grid.Column="1"
                                       Margin="18,0,0,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedProfileValue}" />

                            <TextBlock Grid.Row="1"
                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                       Text="热点状态" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="18,0,0,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding StateValue}" />

                            <TextBlock Grid.Row="2"
                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                       Text="热点名称" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="18,0,0,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentSsidValue}" />

                            <TextBlock Grid.Row="3"
                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                       Text="连接设备数" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="18,0,0,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding ClientCountValue}" />

                            <TextBlock Grid.Row="4"
                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                       Text="上次操作" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="18,0,0,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding OperationValue}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
