<ui:FluentWindow
    x:Class="HotspotShare.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:HotspotShare.ViewModels"
    Title="HotspotShare"
    Width="1220"
    Height="860"
    MinWidth="1000"
    MinHeight="700"
    d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Icon="pack://application:,,,/HotspotShare;component/Assets/icon.ico"
    Loaded="Window_Loaded"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:TitleBarButton}}" TargetType="{x:Type ui:TitleBarButton}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Height="44">
            <ui:TitleBar.Header>
                <StackPanel
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Image
                        Width="34"
                        Height="34"
                        Source="pack://application:,,,/HotspotShare;component/Assets/icon.png"
                        Stretch="Uniform" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="HotspotShare" />
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <StackPanel
                    Margin="0"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <ui:Button
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource TitleBarActionButtonStyle}"
                        ToolTipService.ToolTip="切换主题">
                        <ui:Button.Content>
                            <ui:SymbolIcon
                                FontSize="16"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ui:Button}}}"
                                Symbol="{Binding ThemeIcon}" />
                        </ui:Button.Content>
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView
                x:Name="RootNavigation"
                Width="Auto"
                MinWidth="48"
                PaneDisplayMode="Left">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem
                        x:Name="DashboardNavItem"
                        Click="NavItem_Click"
                        Content="控制台"
                        Icon="{ui:SymbolIcon Wifi320}"
                        Tag="dashboard" />
                    <ui:NavigationViewItem
                        x:Name="DevicesNavItem"
                        Click="NavItem_Click"
                        Content="设备"
                        Icon="{ui:SymbolIcon People20}"
                        Tag="devices" />
                    <ui:NavigationViewItem
                        x:Name="LogsNavItem"
                        Click="NavItem_Click"
                        Content="日志"
                        Icon="{ui:SymbolIcon DocumentText20}"
                        Tag="logs" />
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem
                        x:Name="AboutNavItem"
                        Click="NavItem_Click"
                        Content="关于"
                        Icon="{ui:SymbolIcon Info20}"
                        Tag="about" />
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="24,16,24,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource BodySecondaryTextBlockStyle}" Text="HotspotShare" />
                            <TextBlock
                                Margin="8,0"
                                Style="{StaticResource BodySecondaryTextBlockStyle}"
                                Text="›" />
                            <TextBlock Style="{StaticResource BodySecondaryTextBlockStyle}" Text="桌面工作台" />
                            <TextBlock
                                Margin="8,0"
                                Style="{StaticResource BodySecondaryTextBlockStyle}"
                                Text="›" />
                            <TextBlock Style="{StaticResource BodySecondaryTextBlockStyle}" Text="{Binding SelectedNavigationItem.Title}" />
                        </StackPanel>

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{Binding SelectedNavigationItem.Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            Style="{StaticResource BodySecondaryTextBlockStyle}"
                            Text="{Binding SelectedNavigationItem.Description}" />
                    </StackPanel>

                </Grid>

                <Frame
                    x:Name="ContentFrame"
                    Grid.Row="1"
                    Margin="16,0,16,16"
                    NavigationUIVisibility="Hidden" />
            </Grid>
        </Grid>

        <ui:Card
            Grid.Row="2"
            Margin="16,12,16,16"
            Padding="16,12">
            <DockPanel>
                <ui:ProgressRing
                    Width="18"
                    Height="18"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    IsIndeterminate="True"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ui:SymbolIcon
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                    Symbol="CheckmarkCircle20" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding BusyMessage}" />
            </DockPanel>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
