<ui:FluentWindow x:Class="HotspotShare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="HotspotShare"
        Width="1180"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        FontFamily="Segoe UI Variable Text"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="HotspotShare" />

        <ui:DynamicScrollViewer Grid.Row="1"
                      Padding="24,16,24,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="1360">
                <ui:Card Margin="0,0,0,16"
                         Padding="28"
                         Background="{DynamicResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                         BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                         BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="70"
                                        Height="70"
                                        CornerRadius="22"
                                        Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
                                    <ui:SymbolIcon Symbol="Wifi324"
                                                   FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Margin="18,0,0,0">
                                    <TextBlock FontSize="32"
                                               FontWeight="SemiBold"
                                               Text="Windows 移动热点共享" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource BodySecondaryTextBlockStyle}"
                                               Text="选择网络连接，一键创建 Wi-Fi 热点并共享给其他设备。" />
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Margin="0,24,0,0">
                                <Border Style="{StaticResource StatusChipBorderStyle}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="GlobeDesktop24"
                                                           FontSize="14" />
                                            <TextBlock Margin="8,0,0,0"
                                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                                       Text="共享连接" />
                                        </StackPanel>
                                        <TextBlock x:Name="HeroProfileValueTextBlock"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                                   Text="-" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource StatusChipBorderStyle}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Wifi324"
                                                           FontSize="14" />
                                            <TextBlock Margin="8,0,0,0"
                                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                                       Text="热点状态" />
                                        </StackPanel>
                                        <TextBlock x:Name="HeroStateValueTextBlock"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                                   Text="Unknown" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource StatusChipBorderStyle}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="People24"
                                                           FontSize="14" />
                                            <TextBlock Margin="8,0,0,0"
                                                       Style="{StaticResource MetricLabelTextBlockStyle}"
                                                       Text="连接设备数" />
                                        </StackPanel>
                                        <TextBlock x:Name="HeroClientCountTextBlock"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                                   Text="0" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <ui:Card Grid.Column="1"
                                Margin="24,0,0,0"
                                Padding="22">
                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="使用前检查" />
                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="1. 确保无线网卡支持 Windows 移动热点。" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="2. 以管理员身份运行可以避免共享配置失败。" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="3. 热点密码长度必须在 8 到 63 位之间。" />
                            </StackPanel>
                        </ui:Card>
                    </Grid>
                </ui:Card>

                <ui:InfoBar x:Name="AdminInfoBar"
                            Margin="0,0,0,16"
                            IsOpen="True"
                            IsClosable="False"
                            Severity="Informational"
                            Title="权限检查"
                            Message="正在检查管理员权限..." />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.18*" />
                        <ColumnDefinition Width="0.92*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0"
                             Margin="0,0,16,0"
                             Padding="24">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                       Text="共享设置" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="选择来源连接并设置热点名称与密码。" />

                            <Border Margin="0,20,0,20"
                                    Height="1"
                                    Background="{DynamicResource ControlStrokeColorSecondaryBrush}" />

                            <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="要共享的连接" />
                            <ComboBox x:Name="SourceProfileComboBox"
                                      Margin="0,8,0,0"
                                      MinHeight="42"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="SourceProfileComboBox_SelectionChanged" />
                            <TextBlock x:Name="ProfileHintTextBlock"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="从系统共享连接里选择一个来源连接。" />

                            <TextBlock Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="热点名称（SSID）" />
                            <ui:TextBox x:Name="SsidTextBox"
                                        Margin="0,8,0,0"
                                        MinHeight="42"
                                        MaxLength="32"
                                        ClearButtonEnabled="True"
                                        PlaceholderText="例如 MyHotspot"
                                        Icon="{ui:SymbolIcon Wifi324}" />

                            <TextBlock Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="Wi-Fi 频段" />
                            <ComboBox x:Name="BandComboBox"
                                      Margin="0,8,0,0"
                                      MinHeight="42" />

                            <TextBlock Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="热点密码" />
                            <ui:PasswordBox x:Name="PassphraseBox"
                                            Margin="0,8,0,0"
                                            MinHeight="42"
                                            MaxLength="63"
                                            RevealButtonEnabled="True"
                                            PlaceholderText="至少 8 位"
                                            Icon="{ui:SymbolIcon Password24}" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource BodySecondaryTextBlockStyle}"
                                       Text="建议使用字母和数字组合，避免特殊字符导致某些终端连接失败。" />

                            <WrapPanel Margin="0,24,0,0">
                                <ui:Button x:Name="RefreshProfilesButton"
                                           Margin="0,0,12,0"
                                           Padding="16,10"
                                           Content="刷新连接"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon ArrowClockwise20}"
                                           Click="RefreshProfilesButton_Click" />
                                <ui:Button x:Name="GeneratePasswordButton"
                                           Margin="0,0,12,0"
                                           Padding="16,10"
                                           Content="生成密码"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Key20}"
                                           Click="GeneratePasswordButton_Click" />
                            </WrapPanel>

                            <WrapPanel Margin="0,16,0,0">
                                <ui:Button x:Name="StartSharingButton"
                                           Margin="0,0,12,0"
                                           Padding="16,10"
                                           Content="启动热点并共享"
                                           Appearance="Primary"
                                           Icon="{ui:SymbolIcon Play20}"
                                           Click="StartSharingButton_Click" />
                                <ui:Button x:Name="StopSharingButton"
                                           Margin="0,0,12,0"
                                           Padding="16,10"
                                           Content="停止热点"
                                           Appearance="Danger"
                                           Icon="{ui:SymbolIcon Stop20}"
                                           Click="StopSharingButton_Click" />
                            </WrapPanel>

                            <ui:Card Margin="0,24,0,0"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="操作建议" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodySecondaryTextBlockStyle}"
                                               Text="先确认来源连接已联网，再启动热点。移动热点启动后，状态区会显示当前 SSID、连接设备数和最近一次操作结果。" />
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>
                    </ui:Card>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ui:Card Padding="24">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                           Text="当前状态" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="用 InfoBar 和分组状态字段展示当前共享结果。" />

                                <ui:InfoBar x:Name="ResultInfoBar"
                                            Margin="0,18,0,0"
                                            IsOpen="True"
                                            IsClosable="False"
                                            Severity="Informational"
                                            Title="准备就绪"
                                            Message="等待操作。" />

                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Style="{StaticResource MetricLabelTextBlockStyle}"
                                               Text="共享连接" />
                                    <TextBlock x:Name="SelectedProfileValueTextBlock"
                                               Grid.Column="1"
                                               Margin="18,0,0,0"
                                               FontWeight="SemiBold"
                                               Text="-" />

                                    <TextBlock Grid.Row="1"
                                               Style="{StaticResource MetricLabelTextBlockStyle}"
                                               Text="热点状态" />
                                    <TextBlock x:Name="StateValueTextBlock"
                                               Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="18,0,0,0"
                                               FontWeight="SemiBold"
                                               Text="-" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource MetricLabelTextBlockStyle}"
                                               Text="热点名称" />
                                    <TextBlock x:Name="CurrentSsidValueTextBlock"
                                               Grid.Row="2"
                                               Grid.Column="1"
                                               Margin="18,0,0,0"
                                               FontWeight="SemiBold"
                                               Text="-" />

                                    <TextBlock Grid.Row="3"
                                               Style="{StaticResource MetricLabelTextBlockStyle}"
                                               Text="连接设备数" />
                                    <TextBlock x:Name="ClientCountValueTextBlock"
                                               Grid.Row="3"
                                               Grid.Column="1"
                                               Margin="18,0,0,0"
                                               FontWeight="SemiBold"
                                               Text="0" />

                                    <TextBlock Grid.Row="4"
                                               Style="{StaticResource MetricLabelTextBlockStyle}"
                                               Text="上次操作" />
                                    <TextBlock x:Name="OperationValueTextBlock"
                                               Grid.Row="4"
                                               Grid.Column="1"
                                               Margin="18,0,0,0"
                                               FontWeight="SemiBold"
                                               Text="-" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Grid.Row="1"
                                 Margin="0,16,0,0"
                                 Padding="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                           Text="执行日志" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource BodySecondaryTextBlockStyle}"
                                           Text="保留最近 20 条操作记录，便于排查共享失败原因。" />
                                <ui:TextBox x:Name="LogTextBox"
                                            Grid.Row="2"
                                            Margin="0,18,0,0"
                                            MinHeight="240"
                                            AcceptsReturn="True"
                                            IsReadOnly="True"
                                            TextWrapping="Wrap"
                                            VerticalScrollBarVisibility="Auto"
                                            HorizontalScrollBarVisibility="Disabled"
                                            FontFamily="Consolas"
                                            IsEnabled="False" />
                            </Grid>
                        </ui:Card>
                    </Grid>
                </Grid>
            </StackPanel>
        </ui:DynamicScrollViewer>

        <ui:Card Grid.Row="2"
                 Margin="24,0,24,16"
                 Padding="16,12">
            <DockPanel>
                <ui:ProgressRing x:Name="BusyProgressRing"
                                 Width="18"
                                 Height="18"
                                 Margin="0,0,12,0"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed"
                                 VerticalAlignment="Center" />
                <ui:SymbolIcon x:Name="BusyStateIcon"
                               Symbol="CheckmarkCircle20"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                <TextBlock x:Name="BusyStateTextBlock"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="就绪。" />
            </DockPanel>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
